{
	"version": 6,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 24,
		"patch": 0
	},
	"configurePresets": [
		{
			"name": "base",
			"hidden": true,
			"cacheVariables": {
				"CMAKE_CXX_STANDARD": "23",
				"AQUA_RUNTIME_DIR": "${sourceDir}/external/aqua-runtime"
			}
		},
		{
			"name": "ninja-debug",
			"displayName": "Ninja Debug",
			"inherits": "base",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/ninja-debug",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug"
			}
		},
		{
			"name": "ninja-release",
			"displayName": "Ninja Release",
			"inherits": "base",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/ninja-release",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release"
			}
		},
		{
			"name": "msvc",
			"displayName": "MSVC (Visual Studio 18 2026)",
			"inherits": "base",
			"generator": "Visual Studio 18 2026",
			"architecture": "x64",
			"binaryDir": "${sourceDir}/build/msvc",
			"condition": {
				"type": "equals",
				"lhs": "${hostSystemName}",
				"rhs": "Windows"
			}
		}
	],
	"buildPresets": [
		{
			"name": "debug",
			"displayName": "Debug",
			"configurePreset": "ninja-debug"
		},
		{
			"name": "release",
			"displayName": "Release",
			"configurePreset": "ninja-release"
		},
		{
			"name": "msvc-debug",
			"displayName": "MSVC Debug",
			"configurePreset": "msvc",
			"configuration": "Debug"
		},
		{
			"name": "msvc-release",
			"displayName": "MSVC Release",
			"configurePreset": "msvc",
			"configuration": "Release"
		}
	]
}
